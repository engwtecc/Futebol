{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "sourceMap": true,

    "outDir": "./dist",

    "incremental": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "baseUrl": "./",

    "paths": {
      "*": ["src/*"]
    }
  },

  "include": ["src/**/*", "prisma/**/*"],

  "exclude": ["node_modules", "dist"]
}
